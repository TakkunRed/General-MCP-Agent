# LLM バックエンド接続設定
# OpenAI 互換であれば LM Studio 以外も指定可能
# 例) LM Studio : http://localhost:1234/v1
# 例) Ollama    : http://localhost:11434/v1
# 例) OpenAI    : https://api.openai.com/v1
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
MODEL_NAME=your-model-name        # ← 使用するモデル名に変更

# エージェント動作設定
MAX_STEPS=10
TEMPERATURE=0.1
VERBOSE=true

# ツール結果内の「次の推奨アクション」フィールド名
# mcp_server.py 側のキー名と合わせること
NEXT_ACTION_FIELD=next_recommended_action
